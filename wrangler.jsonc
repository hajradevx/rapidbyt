{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rapidbyt",
  "main": "./.output/server/index.mjs",
  "compatibility_date": "2026-07-12",
  "routes": [
    {
      "pattern": "rapidbyt.com/*",
      "zone_name": "rapidbyt.com",
    },
    {
      "pattern": "www.rapidbyt.com/*",
      "zone_name": "rapidbyt.com",
    },
  ],
  "assets": {
    "directory": "./.output/public/",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "rapidbyt",
      "database_id": "ed77c9c6-add3-477d-ba76-38f3ea26be1c",
      "migrations_table": "_hub_migrations",
      "migrations_dir": "server/db/migrations/sqlite/",
    },
  ],
}
